#!/usr/bin/env bash
# ==============================================================================
# Hydra-Pro Pre-Commit Hook
# ==============================================================================
# Validates changes before commit — blocks dangerous patterns and enforces
# code quality checks on changed files.
#
# Install: ln -sf ../../ci/pre-commit .git/hooks/pre-commit
# ==============================================================================

set -euo pipefail

# ---- Constants ----
readonly MAX_FILE_LINES=800
readonly MAX_DIFF_LINES=60
readonly RED='\033[0;31m'
readonly YELLOW='\033[1;33m'
readonly GREEN='\033[0;32m'
readonly NC='\033[0m' # No Color
readonly BLOCKED_PATTERNS=("TODO" "FIXME" "HACK" "XXX" "TEMP")

# ---- Helpers ----

err()  { printf "${RED}[ERROR]${NC} %s\n" "$*"; }
warn() { printf "${YELLOW}[WARN]${NC}  %s\n" "$*"; }
ok()   { printf "${GREEN}[OK]${NC}    %s\n" "$*"; }

# Get files changed in staging area (new or modified, not deleted)
get_staged_files() {
    git diff --cached --name-only --diff-filter=ACM
}

# Get a file's line count (0 if missing)
file_lines() {
    local f="$1"
    [ -f "$f" ] && wc -l < "$f" || echo 0
}

# ---- Checks ----

check_file_size() {
    local errors=0
    while IFS= read -r file; do
        [ -z "$file" ] && continue
        local lines
        lines=$(file_lines "$file")
        if [ "$lines" -gt "$MAX_FILE_LINES" ]; then
            err "File too large: $file ($lines lines, max $MAX_FILE_LINES)"
            errors=$((errors + 1))
        fi
    done <<< "$(get_staged_files)"
    return "$errors"
}

check_diff_size() {
    local warnings=0
    while IFS= read -r file; do
        [ -z "$file" ] && continue
        local diff_lines
        diff_lines=$(git diff --cached -- "$file" | grep -c '^[+-]' || true)
        if [ "$diff_lines" -gt "$MAX_DIFF_LINES" ]; then
            warn "Large diff: $file ($diff_lines changed lines; consider splitting)"
            warnings=$((warnings + 1))
        fi
    done <<< "$(get_staged_files)"
    return 0 # downgraded to warning
}

check_blocked_patterns() {
    local errors=0
    while IFS= read -r file; do
        [ -z "$file" ] && continue
        # Only check newly added lines (not existing code)
        local new_lines
        new_lines=$(git diff --cached -- "$file" | grep '^+' | grep -v '^+++' || true)
        for pattern in "${BLOCKED_PATTERNS[@]}"; do
            if echo "$new_lines" | grep -qi "$pattern" 2>/dev/null; then
                err "Blocked pattern '$pattern' found in new code: $file"
                errors=$((errors + 1))
            fi
        done
    done <<< "$(get_staged_files)"
    return "$errors"
}

check_go_vet() {
    local changed_go_files
    changed_go_files=$(get_staged_files | grep '\.go$' || true)
    if [ -z "$changed_go_files" ]; then
        return 0
    fi
    if ! command -v go &>/dev/null; then
        warn "go not found — skipping go vet"
        return 0
    fi
    # Vet all packages, not just changed files (vet works at package level)
    if ! go vet ./... 2>&1; then
        err "go vet failed — fix issues before committing"
        return 1
    fi
    ok "go vet passed"
    return 0
}

check_cargo_clippy() {
    local changed_rs_files
    changed_rs_files=$(get_staged_files | grep '\.rs$' || true)
    if [ -z "$changed_rs_files" ]; then
        return 0
    fi
    if ! command -v cargo &>/dev/null; then
        warn "cargo not found — skipping clippy"
        return 0
    fi
    if ! cargo clippy -- -D warnings 2>&1; then
        err "cargo clippy found warnings — fix before committing"
        return 1
    fi
    ok "cargo clippy passed"
    return 0
}

# ---- Main ----

main() {
    local exit_code=0

    echo ""
    echo "Hydra-Pro Pre-Commit Hook"
    echo "========================="

    # 1. File size check (hard block)
    if ! check_file_size; then
        exit_code=1
    else
        ok "File size check passed"
    fi

    # 2. Diff size check (warning only)
    check_diff_size || true

    # 3. Blocked patterns (hard block)
    if ! check_blocked_patterns; then
        exit_code=1
    else
        ok "No blocked patterns in new code"
    fi

    # 4. Go vet
    if ! check_go_vet; then
        exit_code=1
    fi

    # 5. Cargo clippy
    if ! check_cargo_clippy; then
        exit_code=1
    fi

    echo ""
    if [ "$exit_code" -eq 0 ]; then
        printf "${GREEN}All pre-commit checks passed.${NC}\n"
    else
        printf "${RED}Pre-commit checks FAILED. Fix errors above before committing.${NC}\n"
    fi
    echo ""

    return "$exit_code"
}

main "$@"
